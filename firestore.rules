rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 1. Global Primitive for valid document ID
    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\\\-]+$'); 
    }

    // 2. Validation helper for Subscription entity
    function isValidSubscription(data) {
      return data.keys().hasAll(['chatId', 'districtCode', 'districtName', 'createdAt'])
        && data.keys().size() <= 5
        && data.chatId is string
        && data.chatId.size() <= 100
        && data.districtCode is string
        && data.districtCode.size() <= 100
        && data.districtName is string
        && data.districtName.size() <= 100
        && data.createdAt is string
        && (data.get('username', '') is string && data.get('username', '').size() <= 100);
    }

    // 3. Secure rules definition for Subscriptions collection
    match /subscriptions/{chatId} {
      // Unauthenticated reads and writes are allowed ONLY because the client React app
      // is secure and does not talk to Firebase directly - all database traffic is proxied 
      // by our backend running on the Express server. We secure the data structure strictly.
      allow read: if true;
      allow create, update: if isValidId(chatId) && isValidSubscription(request.resource.data);
      allow delete: if isValidId(chatId);
    }
  }
}
